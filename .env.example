# Configuração do Banco de Dados
DATABASE_URL="postgresql://user:password@localhost:5432/albergue"

# Autenticação (Auth.js)
AUTH_SECRET="seu-secret-aqui"

# Segurança
# ENCRYPTION_KEY: Chave de criptografia para dados sensíveis (ex: passaportes).
# Deve ser uma string de 64 caracteres hexadecimais (representando 32 bytes para AES-256).
ENCRYPTION_KEY="000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f"

# i18n
DEFAULT_LOCALE="pt-BR"
